{
  "name": "AI-PAI",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "npm run dev:go",
    "dev:go": "powershell -ExecutionPolicy Bypass -File scripts/dev-go-watch.ps1",
    "dev:go:once": "powershell -ExecutionPolicy Bypass -File scripts/build-go.ps1 -Run",
    "build": "npm run build:all",
    "build:all": "powershell -ExecutionPolicy Bypass -File scripts/build-all.ps1",
    "build:ui": "powershell -ExecutionPolicy Bypass -File scripts/build-ui.ps1",
    "build:go": "powershell -ExecutionPolicy Bypass -File scripts/build-go.ps1",
    "check-release": "powershell -ExecutionPolicy Bypass -File scripts/check-release.ps1",
    "prestart": "powershell -ExecutionPolicy Bypass -File scripts/check-release.ps1",
    "start": ".\\release\\aipi-go.exe",
    "start:server": ".\\release\\aipi-go.exe"
  }
}
